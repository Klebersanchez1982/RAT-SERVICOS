# Configuração de Ambiente - RAT App

# Integração com Google Sheets (opcional)
# Deixe em branco para usar dados mock locais
# Preencha com a URL do Google Apps Script para usar backend remoto
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/SEU_ID/exec

# CNPJ da empresa para isolamento multiempresa
# Exemplo: 12.345.678/0001-90
VITE_CNPJ=12.345.678/0001-90
